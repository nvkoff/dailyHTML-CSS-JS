      "code": "const user = null;\nconsole.log(user?.name);",
      "options": ["null", "undefined", "TypeError", "'null'"],
      "answer": 1,
      "explanation": "?.name short-circuits to undefined when the left side is null or undefined — no TypeError."
    }
