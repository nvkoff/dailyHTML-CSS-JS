  "questions": [
    {
      "type": "predict",
      "prompt": "What logs?",
      "language": "js",
      "code": "const count = 0 ?? 5;\nconsole.log(count);",
      "options": ["0", "5", "null", "undefined"],
      "answer": 0,
      "explanation": "?? only falls through for null or undefined. 0 is a valid number, so keep it."
    },
    {
      "type": "predict",
      "prompt": "What logs?",
      "language": "js",
      "code": "const count = 0 || 5;\nconsole.log(count);",
      "options": ["0", "5", "null", "undefined"],
      "answer": 1,
      "explanation": "|| falls through on ANY falsy value, including 0. That's why ?? is safer for defaults."
    },
    {
      "type": "predict",
