      "prompt": "Which is the SHORTEST correct arrow function that doubles n?",
      "options": [
        "n => { n * 2 }",
        "n => n * 2",
        "(n) => return n * 2",
        "n => (n * 2;)"
      ],
      "answer": 1,
      "explanation": "No braces = implicit return. Braces require an explicit return."
