      "prompt": "What logs?",
      "language": "js",
      "code": "console.log(!!'hello');",
      "options": ["true", "false", "'hello'", "TypeError"],
      "answer": 0,
      "explanation": "!!x converts x to a boolean. 'hello' is truthy → true."
    },
    {
      "type": "predict",
      "prompt": "What logs?",
      "language": "js",
      "code": "console.log(true + true);",
      "options": ["true", "2", "1", "'truetrue'"],
      "answer": 1,
      "explanation": "Booleans coerce to numbers: true → 1, false → 0. 1 + 1 = 2."
