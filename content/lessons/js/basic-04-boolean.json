    {
      "type": "mcq",
      "prompt": "Which is NOT falsy?",
      "options": ["undefined", "NaN", "-0", "'false'"],
      "answer": 3,
      "explanation": "Falsy: false, 0, -0, 0n, '', null, undefined, NaN. Everything else is truthy."
