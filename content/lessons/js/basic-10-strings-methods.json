      "code": "console.log('abcde'.slice(1, 3));",
      "options": ["'bc'", "'bcd'", "'abc'", "'ab'"],
      "answer": 0,
      "explanation": "slice(start, end): end is EXCLUSIVE. Positions 1..2 → 'bc'."
    },
    {
      "type": "predict",
      "prompt": "What logs?",
      "language": "js",
      "code": "console.log('hi'.repeat(3));",
      "options": ["'hi'", "'hihihi'", "['hi','hi','hi']", "3"],
      "answer": 1,
      "explanation": "repeat concatenates the string n times."
    },
    {
      "type": "predict",
      "prompt": "What logs?",
      "language": "js",
      "code": "console.log('a-b-c'.split('-'));",
