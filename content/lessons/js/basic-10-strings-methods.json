    {
      "type": "predict",
      "prompt": "What logs?",
      "language": "js",
      "code": "console.log('Hello'.toLowerCase());",
      "options": ["'HELLO'", "'hello'", "'Hello'", "'hELLO'"],
      "answer": 1,
      "explanation": "toLowerCase / toUpperCase return NEW strings; strings are immutable."
    },
    {
      "type": "predict",
      "prompt": "What logs?",
