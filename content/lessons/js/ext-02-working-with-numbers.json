  "questions": [
    {
      "type": "mcq",
      "prompt": "Which converts '42' to the NUMBER 42?",
      "options": ["Number('42')", "+'42'", "parseInt('42', 10)", "All of them"],
      "answer": 3,
      "explanation": "All three work; parseInt with radix 10 is safest for user input."
    },
    {
      "type": "predict",
      "prompt": "What logs?",
      "language": "js",
      "code": "console.log(parseInt('12abc'));",
      "options": ["NaN", "12", "'12abc'", "0"],
      "answer": 1,
      "explanation": "parseInt reads leading digits and stops at the first non-digit."
    },
    {
      "type": "predict",
      "prompt": "What logs?",
      "language": "js",
      "code": "console.log(Number('12abc'));",
      "options": ["NaN", "12", "'12abc'", "0"],
      "answer": 0,
      "explanation": "Number() requires the ENTIRE string to be a valid number."
    },
    {
      "type": "predict",
      "prompt": "What logs?",
      "language": "js",
      "code": "console.log(Math.round(2.5));",
      "options": ["2", "3", "2.5", "-3"],
      "answer": 1,
      "explanation": "Math.round rounds half UP for positive numbers. Note: Math.round(-2.5) → -2."
    },
    {
      "type": "predict",
      "prompt": "What logs?",
      "language": "js",
      "code": "console.log(Math.floor(-2.5));",
      "options": ["-2", "-3", "2", "3"],
      "answer": 1,
      "explanation": "floor rounds toward -Infinity. trunc would give -2."
    },
    {
      "type": "predict",
      "prompt": "What logs?",
      "language": "js",
      "code": "console.log(2 ** 10);",
      "options": ["100", "1024", "20", "TypeError"],
      "answer": 1,
      "explanation": "** is the exponent operator. Same as Math.pow(2, 10)."
    },
    {
      "type": "predict",
      "prompt": "What logs?",
      "language": "js",
      "code": "console.log((1.005).toFixed(2));",
      "options": ["'1.01'", "'1.00'", "'1.005'", "'1.010'"],
      "answer": 1,
      "explanation": "Floating-point again — 1.005 is actually stored slightly less, so toFixed(2) → '1.00'."
    },
    {
      "type": "predict",
      "prompt": "What logs?",
